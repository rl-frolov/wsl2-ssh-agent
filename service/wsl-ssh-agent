#!/usr/bin/env bash
set -euo pipefail

AGENT_BASE="${XDG_RUNTIME_DIR%/}"
AGENT_SOCKET="$AGENT_BASE/agent.sock"
NPIPERELAY_BIN="${HOME}/winhome/.wsl/npiperelay.exe"   # adjust as needed

check_prerequisites() {
    if ! command -v socat &>/dev/null; then
        echo "ERROR: socat not found. Install with: sudo apt install socat" >&2
        return 1
    fi
    if [[ ! -x "$NPIPERELAY_BIN" ]]; then
        echo "ERROR: npiperelay.exe not executable at: $NPIPERELAY_BIN" >&2
        echo "Download from: https://github.com/jstarks/npiperelay/releases" >&2
        return 1
    fi
    return 0
}

# Check if systemd user service is installed
SERVICE_INSTALLED=0
if systemctl --user list-unit-files 2>/dev/null | grep -q "wsl-ssh-agent.service"; then
    SERVICE_INSTALLED=1
fi

check_installed() {
    if (( ! SERVICE_INSTALLED )); then
        echo "ERROR: wsl-ssh-agent is not installed as a systemd user service." >&2
        echo "Run the install script (scripts/install.sh) first." >&2
        exit 1
    fi
}

case "${1:-usage}" in
# GENERAL FUNCTIONALITY
    usage)
        echo "Usage: $(basename -- $0) {foreground|debug|print-env} [--version] [--help]"
        if (( $SERVICE_INSTALLED )); then
            echo "       $(basename -- $0) <service_command> [options]"
        fi
        ;;
    foreground)
        check_prerequisites || exit 1
        if [[ -S "$AGENT_SOCKET" ]]; then
            echo "ERROR: Socket already exists at $AGENT_SOCKET. Another instance may be running." >&2
            exit 1
        fi

        socat_cmd="socat"
        [[ -v SOCAT_VERBOSE ]] && socat_cmd="socat -d -d"

        exec $socat_cmd UNIX-LISTEN:"$AGENT_SOCKET",fork \
            EXEC:"$NPIPERELAY_BIN -ei -s //./pipe/openssh-ssh-agent"
        ;;
    debug)
        export SOCAT_VERBOSE=1
        exec "$0" foreground
        ;;
    print-env)
        echo "export SSH_AUTH_SOCK=\"$AGENT_SOCKET\""
        ;;
# SYSTEMD EXTENSION
    status)
        check_installed
        exec systemctl --user status wsl-ssh-agent.service
        ;;
    start)
        check_installed
        exec systemctl --user start wsl-ssh-agent.service
        ;;
    stop)
        check_installed
        exec systemctl --user stop wsl-ssh-agent.service
        ;;
    restart)
        check_installed
        exec systemctl --user restart wsl-ssh-agent.service
        ;;
    autorun)
        check_installed
        exec systemctl --user enable wsl-ssh-agent.service
        ;;
    no-autorun)
        check_installed
        exec systemctl --user enable wsl-ssh-agent.service
        ;;
    reload)
        check_installed
        exec systemctl --user daemon-reload
        ;;
    journal)
        check_installed
        shift
        exec journalctl --user-unit wsl-ssh-agent.service "$@"
        ;;
# INFO
    --version|-v)
        echo "wsl-ssh-agent 1.0.0"
        ;;

    --help|-h)
        $0 usage
        cat <<EOF

  usage           Show brief usage syntax
  foreground      Run the SSH agent relay (for systemd or manual use).
  debug           Run the relay with full socat debug output.
  print-env       Print the SSH_AUTH_SOCK export line.
  -v --version    Show version.
  -h --help       Show this help.
EOF
    if (( SERVICE_INSTALLED )); then
        cat <<EOF

Systemd service commands:
  status       Show service status.
  start        Start the agent service.
  stop         Stop the agent service.
  restart      Restart the agent service.
  autorun      Enable automatic start on login.
  no-autorun   Disable automatic start on login.
  reload       Reload systemd user daemon.
  journal      Show logs (supports journalctl options).
EOF
        fi
        ;;

    *)
        echo "Unknown command: $1" >&2
        exit 1
        ;;
esac
